---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import WorkDetailHero from "../../components/WorkDetailHero.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Trial Delivery — Vult Labs" description="End-to-end courtroom presentation services. Visual evidence organized, formatted, and delivered for trial.">
  <Nav />
  <WorkDetailHero title="Trial Delivery." variant="trial" />

  <main>
    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-meta-row">
          <div>
            <div class="wd-label">Service</div>
            <div class="wd-value">Courtroom Presentation &<br />Exhibit Management</div>
          </div>
          <div>
            <div class="wd-label">Deliverables</div>
            <div class="wd-value">Trial-ready packages<br />Presentation systems<br />Exhibit management</div>
          </div>
          <a class="wd-back" href="/#work">← Work</a>
        </div>

        <div class="wd-caps">
          <div class="wd-caps-label">Capabilities</div>
          <div class="wd-caps-grid">
            <span>Trial presentation</span>
            <span>Exhibit sequencing</span>
            <span>Hardware coordination</span>
            <span>Real-time annotation</span>
            <span>Multi-screen setup</span>
            <span>Courtroom-ready output</span>
          </div>
        </div>
      </div>
    </section>

    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-divider"></div>
      </div>
    </section>

    <section class="wd-desc">
      <div class="wd-desc-inner">
        <p class="wd-desc-text">
          End-to-end courtroom presentation services. We organize, format,
          and deliver your visual evidence so it works seamlessly at
          trial — from screen to jury.
        </p>
      </div>
    </section>

    <section class="wd-gallery">
      <div class="wd-gallery-inner">
        <div class="wd-gallery-label">Selected Work</div>
        <div class="wd-gallery-grid">
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
        </div>
      </div>
    </section>

    <div class="wd-cta">
      <a class="wd-cta-link" href="/#contact">⟶ <span>Get Started</span></a>
    </div>

    <Footer />
  </main>
</Base>
