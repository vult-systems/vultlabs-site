---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import WorkDetailHero from "../../components/WorkDetailHero.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Medical — Vult Labs" description="Precise medical-legal visuals that translate injury data into clear, compelling courtroom evidence.">
  <Nav />
  <WorkDetailHero title="Medical." variant="medical" />

  <main>
    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-meta-row">
          <div>
            <div class="wd-label">Service</div>
            <div class="wd-value">Medical Visualization &<br />Illustration</div>
          </div>
          <div>
            <div class="wd-label">Deliverables</div>
            <div class="wd-value">Anatomical illustrations<br />Surgical animations<br />Injury diagrams</div>
          </div>
          <a class="wd-back" href="/#work">← Work</a>
        </div>

        <div class="wd-caps">
          <div class="wd-caps-label">Capabilities</div>
          <div class="wd-caps-grid">
            <span>Anatomical illustration</span>
            <span>Surgical animation</span>
            <span>Injury documentation</span>
            <span>Skeletal modeling</span>
            <span>Soft-tissue rendering</span>
            <span>Courtroom-ready output</span>
          </div>
        </div>
      </div>
    </section>

    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-divider"></div>
      </div>
    </section>

    <section class="wd-desc">
      <div class="wd-desc-inner">
        <p class="wd-desc-text">
          Precise medical-legal visuals that translate injury data into clear,
          compelling courtroom evidence. From skeletal fractures to
          soft-tissue damage, every detail is rendered with
          clinical accuracy.
        </p>
      </div>
    </section>

    <section class="wd-gallery">
      <div class="wd-gallery-inner">
        <div class="wd-gallery-label">Selected Work</div>
        <div class="wd-gallery-grid">
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
        </div>
      </div>
    </section>

    <div class="wd-cta">
      <a class="wd-cta-link" href="/#contact">⟶ <span>Get Started</span></a>
    </div>

    <Footer />
  </main>
</Base>
