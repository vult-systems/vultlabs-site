---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import WorkDetailHero from "../../components/WorkDetailHero.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Crash | Vult Labs" description="Cinematic crash reconstruction visuals. Stills and motion built from verified data, structured for the courtroom.">
  <Nav />
  <WorkDetailHero title="Crash." variant="scene" />

  <main>
    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-meta-row">
          <div>
            <div class="wd-label">Focus</div>
            <div class="wd-value">Crash Reconstruction<br />Collision Visualization<br />Vehicle Dynamics</div>
          </div>
          <div>
            <div class="wd-label">Motion</div>
            <div class="wd-value">Crash reconstruction animation<br />Vehicle movement and timing<br />Collision sequence playback<br />Camera-driven crash views</div>
          </div>
          <div>
            <div class="wd-label">Stills</div>
            <div class="wd-value">Impact moment frames<br />Vehicle position diagrams<br />Scene overview visuals<br />Exhibit-ready crash frames</div>
          </div>
        </div>
        <p class="wd-meta-note">Projects may include motion, stills, or a combination of both.</p>
      </div>
    </section>

    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-divider"></div>
      </div>
    </section>

    <section class="wd-desc">
      <div class="wd-desc-inner">
        <p class="wd-desc-text">
          Crash reconstructions translate crash data and expert findings into clear visual accounts of how the collision occurred.
        </p>
        <p class="wd-desc-text">
          Each project begins with verified case materials and expert analysis. These elements are reconstructed through the craft of our studio to show how the collision occurred and why it matters.
        </p>
        <a class="arrow" href="#" data-open-modal="case"><img class="arrow-icon" src="/icons/arrow-lng.svg" alt="" /><span>Discuss Your Case</span></a>
      </div>
    </section>

    <Footer />
  </main>
</Base>
