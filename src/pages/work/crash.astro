---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import WorkDetailHero from "../../components/WorkDetailHero.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Crash — Vult Labs" description="Cinematic crash reconstruction visuals. Stills and motion built from verified data, structured for the courtroom.">
  <Nav />
  <WorkDetailHero title="Crash." variant="scene" />

  <main>
    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-meta-row">
          <div>
            <div class="wd-label">Category</div>
            <div class="wd-value">Crash Reconstruction</div>
          </div>
          <div>
            <div class="wd-label">Offerings</div>
            <div class="wd-value">Stills<br />Motion</div>
          </div>
          <a class="wd-back" href="/#work">← Work</a>
        </div>

        <div class="wd-caps">
          <div class="wd-caps-label">Capabilities</div>
          <div class="wd-caps-grid">
            <span>Scene photography</span>
            <span>3D reconstruction</span>
            <span>Aerial mapping</span>
            <span>Forensic documentation</span>
            <span>Physics-based animation</span>
            <span>Timeline visualization</span>
            <span>Annotated exhibits</span>
            <span>Expert collaboration</span>
            <span>Courtroom-ready output</span>
          </div>
        </div>
      </div>
    </section>

    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-divider"></div>
      </div>
    </section>

    <section class="wd-desc">
      <div class="wd-desc-inner">
        <p class="wd-desc-text">
          Cinematic crash reconstruction — stills and motion — built from
          verified data to make complex accidents undeniable. Every frame
          is accurate to the physics, structured for the courtroom.
        </p>
      </div>
    </section>

    <section class="wd-gallery">
      <div class="wd-gallery-inner">
        <div class="wd-gallery-label">Selected Work</div>
        <div class="wd-gallery-grid">
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
          <div class="wd-gallery-item"></div>
        </div>
      </div>
    </section>

    <div class="wd-cta">
      <a class="wd-cta-link" href="/#contact"><svg class="arrow-icon" viewBox="0 0 48 12" xmlns="http://www.w3.org/2000/svg"><path d="M0 6 H36 L30 1 L38 6 L30 11 L36 6" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="miter"/></svg><span>Get Started</span></a>
    </div>

    <Footer />
  </main>
</Base>
