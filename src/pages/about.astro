---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Base title="About — Vult Labs" description="Vult builds cinematic litigation visuals that turn complex accidents, injuries, and technical failures into clear visual evidence.">
  <Nav />

  <section class="wd-hero" style="background: linear-gradient(160deg, #1a1a1e 0%, #0b0d0f 60%);">
    <div class="wd-hero-overlay"></div>
    <div class="wd-hero-title">
      <h1 class="wd-title">About Vult.</h1>
    </div>
  </section>

  <main>
    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-meta-row">
          <div>
            <div class="wd-label">Produced by</div>
            <div class="wd-value">Vult</div>
          </div>
          <div>
            <div class="wd-label">Studio</div>
            <div class="wd-value">San Antonio, Texas</div>
          </div>
          <div>
            <div class="wd-label">Year</div>
            <div class="wd-value">2025</div>
          </div>
          <div>
            <div class="wd-label">Specializing in</div>
            <div class="wd-value">Crash Reconstruction, Medical Visualization, Cinematic Case Visualization</div>
          </div>
        </div>
      </div>
    </section>

    <section class="wd-meta">
      <div class="wd-meta-inner">
        <div class="wd-divider"></div>
      </div>
    </section>

    <section class="wd-desc">
      <div class="wd-desc-inner">
        <p class="wd-desc-text">
          Vult is a visualization studio specializing in cinematic litigation reconstructions. Crash dynamics, injury mechanisms, and expert analysis are translated into clear visual narratives built from verified case data.
        </p>
        <p class="wd-desc-text">
          Every reconstruction begins with evidence and ends with the craft of a production studio. The result is visual evidence that clarifies complex events and holds under scrutiny in mediation and trial.
        </p>
        <a class="arrow" href="/#contact"><img class="arrow-icon" src="/icons/arrow-lng.svg" alt="" /><span>Discuss Your Case</span></a>
      </div>
    </section>

    <Footer />
  </main>
</Base>
