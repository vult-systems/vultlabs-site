---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Vult Labs — Cinematic Litigation Visuals",
  description = "Vult builds cinematic litigation visuals that turn complex accidents, injuries, and technical failures into clear visual evidence. Accurate to the data. Structured for the courtroom.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://vultlabs.com" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <slot />
  </body>
</html>
