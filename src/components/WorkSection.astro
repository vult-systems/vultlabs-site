---
interface Props {
  title: string;
  items: string[];
  variant: string;
  flip?: boolean;
  href?: string;
}

const { title, items, variant, flip = false, href } = Astro.props;
---

<section class="section">
  <div class:list={["grid", "two", { flip }]}>
    {flip ? (
      <Fragment>
        <div class="copy">
          <div class="kicker">Work</div>
          <h3>{href ? <a href={href}>{title}</a> : title}</h3>
          <ul class="mini">
            {items.map((item) => <li>{item}</li>)}
          </ul>
          <a class="arrow" href={href || "#contact"}>⟶ <span>{href ? "View" : "Get Started"}</span></a>
        </div>
        <a class="card media work-link" href={href || "#"}>
          <div class={`media-placeholder ${variant}`}></div>
        </a>
      </Fragment>
    ) : (
      <Fragment>
        <a class="card media work-link" href={href || "#"}>
          <div class={`media-placeholder ${variant}`}></div>
        </a>
        <div class="copy">
          <div class="kicker">Work</div>
          <h3>{href ? <a href={href}>{title}</a> : title}</h3>
          <ul class="mini">
            {items.map((item) => <li>{item}</li>)}
          </ul>
          <a class="arrow" href={href || "#contact"}>⟶ <span>{href ? "View" : "Get Started"}</span></a>
        </div>
      </Fragment>
    )}
  </div>
</section>
