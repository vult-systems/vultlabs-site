---
interface Props {
  title: string;
  description: string;
  variant: string;
  flip?: boolean;
  href?: string;
}

const { title, description, variant, flip = false, href } = Astro.props;
---

<section class="section">
  <div class:list={["grid", "two", { flip }]}>
    {flip ? (
      <Fragment>
        <div class="copy">
          <div class="kicker">Work</div>
          <h3>{href ? <a href={href}>{title}</a> : title}</h3>
          <p class="section-desc">{description}</p>
          <a class="arrow" href={href || "#contact"}><img class="arrow-icon arrow-lng" src="/icons/arrow-lng.svg" alt="" /><img class="arrow-icon arrow-sht" src="/icons/arrow-sht.svg" alt="" /><span>{href ? "View Work" : "Get Started"}</span></a>
        </div>
        <a class="card media work-link" href={href || "#"}>
          <div class={`media-placeholder ${variant}`}></div>
        </a>
      </Fragment>
    ) : (
      <Fragment>
        <a class="card media work-link" href={href || "#"}>
          <div class={`media-placeholder ${variant}`}></div>
        </a>
        <div class="copy">
          <div class="kicker">Work</div>
          <h3>{href ? <a href={href}>{title}</a> : title}</h3>
          <p class="section-desc">{description}</p>
          <a class="arrow" href={href || "#contact"}><img class="arrow-icon arrow-lng" src="/icons/arrow-lng.svg" alt="" /><img class="arrow-icon arrow-sht" src="/icons/arrow-sht.svg" alt="" /><span>{href ? "View Work" : "Get Started"}</span></a>
        </div>
      </Fragment>
    )}
  </div>
</section>
