---
interface Props {
  title: string;
  description: string;
  variant: string;
  flip?: boolean;
  href?: string;
}

const { title, description, variant, flip = false, href } = Astro.props;
---

<section class="section">
  <div class:list={["grid", "two", { flip }]}>
    {flip ? (
      <Fragment>
        <div class="copy">
          <div class="kicker">Work</div>
          <h3>{href ? <a href={href}>{title}</a> : title}</h3>
          <p class="section-desc">{description}</p>
          <a class="arrow" href={href || "#contact"}><svg class="arrow-icon" viewBox="0 0 40 12" xmlns="http://www.w3.org/2000/svg"><path d="M0 5 H30 V1 L40 6 L30 11 V7 H0 Z" fill="currentColor"/></svg><span>{href ? "View Work" : "Get Started"}</span></a>
        </div>
        <a class="card media work-link" href={href || "#"}>
          <div class={`media-placeholder ${variant}`}></div>
        </a>
      </Fragment>
    ) : (
      <Fragment>
        <a class="card media work-link" href={href || "#"}>
          <div class={`media-placeholder ${variant}`}></div>
        </a>
        <div class="copy">
          <div class="kicker">Work</div>
          <h3>{href ? <a href={href}>{title}</a> : title}</h3>
          <p class="section-desc">{description}</p>
          <a class="arrow" href={href || "#contact"}><svg class="arrow-icon" viewBox="0 0 40 12" xmlns="http://www.w3.org/2000/svg"><path d="M0 5 H30 V1 L40 6 L30 11 V7 H0 Z" fill="currentColor"/></svg><span>{href ? "View Work" : "Get Started"}</span></a>
        </div>
      </Fragment>
    )}
  </div>
</section>
