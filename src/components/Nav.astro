---
---

<nav class="nav" id="nav">
  <button class="nav-left nav-toggle" aria-label="Toggle menu" aria-expanded="false">
    <span class="hamburger"></span>
    <span class="menu-label">Menu</span>
  </button>
  <a class="nav-center" href="#top">
    <img src="/images/logo.svg" alt="Vult" class="nav-logo" />
    <span class="logo-text">Vult</span>
  </a>
  <a class="nav-right" href="#contact" aria-label="Search">⌕</a>
</nav>

<!-- Floating hamburger: always visible when nav is hidden -->
<button class="floating-hamburger" id="floating-hamburger" aria-label="Toggle menu" aria-expanded="false">
  <span class="hamburger"></span>
</button>

<div class="side-menu-overlay" id="side-menu-overlay"></div>
<div class="side-menu" id="side-menu">
  <nav class="side-menu-links">
    <a href="#work">Work</a>
    <a href="#contact">Contact</a>
  </nav>
</div>

<script>
  const navToggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const floatingToggle = document.getElementById('floating-hamburger') as HTMLButtonElement;
  const sideMenu = document.getElementById('side-menu') as HTMLElement;
  const sideOverlay = document.getElementById('side-menu-overlay') as HTMLElement;
  const menuLabel = navToggle?.querySelector('.menu-label') as HTMLElement;

  function openMenu() {
    sideMenu.classList.add('open');
    sideOverlay.classList.add('open');
    navToggle.setAttribute('aria-expanded', 'true');
    floatingToggle.setAttribute('aria-expanded', 'true');
    if (menuLabel) menuLabel.textContent = 'Close';
  }

  function closeMenu() {
    sideMenu.classList.remove('open');
    sideOverlay.classList.remove('open');
    navToggle.setAttribute('aria-expanded', 'false');
    floatingToggle.setAttribute('aria-expanded', 'false');
    if (menuLabel) menuLabel.textContent = 'Menu';
  }

  function toggleMenu() {
    if (sideMenu.classList.contains('open')) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  navToggle?.addEventListener('click', toggleMenu);
  floatingToggle?.addEventListener('click', toggleMenu);
  sideOverlay?.addEventListener('click', closeMenu);

  sideMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Scroll behavior
  const nav = document.getElementById('nav') as HTMLElement;
  const hero = document.querySelector('.hero') as HTMLElement;
  let lastScrollY = 0;
  let ticking = false;

  function onScroll() {
    const currentY = window.scrollY;
    const heroBottom = hero ? hero.offsetHeight : 500;
    const scrollingDown = currentY > lastScrollY;
    const pastHero = currentY > heroBottom;

    if (currentY <= 60) {
      // At top: transparent nav, no hiding
      nav.classList.remove('nav-hidden', 'nav-solid');
      floatingToggle.classList.remove('visible', 'dark');
    } else if (scrollingDown && currentY > 80) {
      // Scrolling down: hide nav, show floating hamburger
      nav.classList.add('nav-hidden');
      floatingToggle.classList.add('visible');
      if (pastHero) {
        floatingToggle.classList.add('dark');
      } else {
        floatingToggle.classList.remove('dark');
      }
    } else if (!scrollingDown) {
      // Scrolling up: show nav
      nav.classList.remove('nav-hidden');
      floatingToggle.classList.remove('visible');
      if (pastHero) {
        // Past hero: solid white nav with dark text
        nav.classList.add('nav-solid');
      } else {
        // Still in hero: transparent with white text
        nav.classList.remove('nav-solid');
      }
    }

    lastScrollY = currentY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(onScroll);
      ticking = true;
    }
  });
</script>
