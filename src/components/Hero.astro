---
import { Image } from "astro:assets";
import heroImg from "../assets/images/hero/landing-page-hero.jpg";
---

<header class="hero" id="top">
  <div class="hero-content">
    <h1>Make it undeniable.</h1>
    <p class="lead">
      Cinematic reconstructions of crashes and injuries built from verified case data for the courtroom.
    </p>
    <a class="cta" href="#" data-open-modal="case">Discuss Your Case</a>
  </div>

  <div class="hero-overlay"></div>
  <Image src={heroImg} alt="" class="hero-bg-img" loading="eager" />
</header>
