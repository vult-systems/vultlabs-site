<footer class="footer" id="contact">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col">
        <div class="footer-links">
          <a href="/about">About</a>
          <a href="/work/crash">Crash</a>
          <a href="/work/medical">Medical</a>
        </div>
        <div class="fineprint">
          &copy; 2026 Vult Systems, LLC.<br />
          All rights reserved. <a href="#">Privacy Policy</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-title">More Vult</div>
        <div class="footer-links dim">
          <a href="https://www.linkedin.com/company/vultlabs" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://www.instagram.com/vultlabs" target="_blank" rel="noopener noreferrer">Instagram</a>
